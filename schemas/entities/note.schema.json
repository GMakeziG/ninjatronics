{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "note.schema.json",
  "title": "Note",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "type": { "const": "note" },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "districtId": { "type": "string", "x-ref": "district" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "obsidianPath": { "type": "string" }
  }
}
