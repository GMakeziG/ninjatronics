{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "experience.schema.json",
  "title": "Experience",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "employer", "role", "startDate", "summary"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "type": { "const": "experience" },
    "employer": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "minLength": 1 },
    "startDate": { "type": "string", "format": "date" },
    "endDate": { "type": "string", "format": "date" },
    "current": { "type": "boolean" },
    "location": { "type": "string" },
    "summary": { "type": "string", "minLength": 1 },
    "order": { "type": "integer" },
    "highlights": {
      "type": "array",
      "items": { "type": "string" }
    },
    "technologies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url"],
        "properties": {
          "label": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        }
      }
    },
    "districtId": { "type": "string", "x-ref": "district" }
  },
  "if": {
    "properties": { "current": { "const": true } },
    "required": ["current"]
  },
  "then": {
    "not": { "required": ["endDate"] }
  }
}
