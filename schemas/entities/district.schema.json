{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "district.schema.json",
  "title": "District",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "slug", "status"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "type": { "const": "district" },
    "name": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "status": { "type": "string", "enum": ["locked", "open", "in-progress"] },
    "guardianId": { "type": "string", "x-ref": "guardian" },
    "subtitle": { "type": "string" },
    "description": { "type": "string" },
    "dataSources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "enum": ["github", "obsidian", "manual"] },
          "owner": { "type": "string" },
          "vaultPath": { "type": "string" }
        }
      }
    },
    "connections": {
      "type": "array",
      "items": { "type": "string", "x-ref": "district" }
    }
  }
}
