{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "project.schema.json",
  "title": "Project",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "status"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "type": { "const": "project" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "status": { "type": "string", "enum": ["planned", "in-progress", "completed"] },
    "districtId": { "type": "string", "x-ref": "district" },
    "repositoryId": { "type": "string", "x-ref": "repository" },
    "technologies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "skillIds": {
      "type": "array",
      "items": { "type": "string", "x-ref": "skill" }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url"],
        "properties": {
          "label": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        }
      }
    }
  }
}
